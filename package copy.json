{
  "name": "smartmove-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "worker": "tsx src/server/workers/index.ts",
    "worker:vision": "tsx src/server/workers/vision.worker.ts",
    "worker:match": "tsx src/server/workers/match.worker.ts",
    "worker:invoice": "tsx src/server/workers/invoice.worker.ts",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "next": "^16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",

    "@prisma/client": "^6.0.0",

    "next-auth": "5.0.0-beta.25",
    "@auth/prisma-adapter": "^2.7.4",
    "bcryptjs": "^2.4.3",

    "@hookform/resolvers": "^3.10.0",
    "react-hook-form": "^7.54.2",
    "zod": "^3.24.1",

    "@google/generative-ai": "^0.21.0",

    "gsap": "^3.12.5",
    "@gsap/react": "^2.1.2",
    "framer-motion": "^12.0.0",

    "next-intl": "^3.26.0",

    "bullmq": "^5.34.0",
    "ioredis": "^5.4.2",

    "@aws-sdk/client-s3": "^3.713.0",
    "@aws-sdk/s3-request-presigner": "^3.713.0",

    "sonner": "^1.7.1",
    "lucide-react": "^0.470.0",
    "date-fns": "^4.1.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "class-variance-authority": "^0.7.1",

    "@sentry/nextjs": "^8.46.0",
    "posthog-js": "^1.205.0",
    "posthog-node": "^4.3.2",

    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",

    "xmlbuilder2": "^3.1.1",
    "qrcode": "^1.5.4",
    "pdfkit": "^0.16.0",
    "resend": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/qrcode": "^1.5.5",
    "@types/pdfkit": "^0.13.6",

    "typescript": "^5.7.2",

    "prisma": "^6.0.0",
    "tsx": "^4.19.2",

    "@tailwindcss/postcss": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",

    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prettier-plugin-prisma": "^5.0.0",

    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",

    "vitest": "^2.1.8",
    "@vitejs/plugin-react": "^4.3.4",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@playwright/test": "^1.49.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": "prettier --write",
    "*.{ts,tsx}": "eslint --fix"
  }
}
