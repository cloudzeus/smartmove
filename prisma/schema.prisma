// =====================================================================
// SmartMove — Prisma Schema (MVP)
//
// Minimal schema for current scope: authentication + move requests.
// Full domain schema (carriers, auctions, payments, PostGIS) lives in
// schema.full.prisma.reference and gets layered in later milestones.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------
// AUTH.JS v5 — required tables
// ---------------------------------------------------------------------

enum UserRole {
  SUPERADMIN
  EMPLOYEE
  TENANTADMIN
  TENANTEMPLOYEE
  CUSTOMER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  passwordHash  String?

  role     UserRole @default(CUSTOMER)
  locale   String   @default("el")
  timezone String   @default("Europe/Athens")

  marketingConsent Boolean   @default(false)
  dataConsent      Boolean   @default(false)
  consentAt        DateTime?

  // Internal staff (EMPLOYEE / SUPERADMIN) controls:
  //   `active` lets an admin disable login without losing audit history
  //   `permissions` is a list of granular permission keys (see lib/permissions.ts)
  //   `invitedAt` / `invitedById` track who provisioned the account
  active        Boolean   @default(true)
  permissions   String[]  @default([])
  invitedAt     DateTime?
  invitedById   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Data retention — free until `dataRetentionUntil`. After expiry the user
  // must consent / pay to keep their data. Set on first sign-in to
  // createdAt + SystemSettings.retentionFreeMonths.
  dataRetentionUntil     DateTime?
  retentionConsentAt     DateTime?
  retentionExtendedUntil DateTime?

  // Gemini AI per-user quota (rolling monthly window)
  geminiCallsTotal       Int      @default(0)
  geminiCallsThisPeriod  Int      @default(0)
  geminiPeriodStart      DateTime @default(now())
  geminiPaidExtraCalls   Int      @default(0)

  // Terms & Conditions acceptance — semver of the TermsVersion the user accepted.
  // Null until they accept the first time; reset whenever a new active version is
  // published and the user must re-accept.
  termsAcceptedVersion String?
  termsAcceptedAt      DateTime?

  accounts           Account[]
  sessions           Session[]
  moveRequests       MoveRequest[]
  savedLocations     SavedLocation[]
  savedItems         SavedItem[]
  carrierOffers      Offer[]    @relation("CarrierOffers")
  payments           Payment[]
  reviewsWritten     Review[]   @relation("ReviewAuthor")
  reviewsReceived    Review[]   @relation("ReviewSubject")
  tenantMemberships  TenantMembership[]
  billingProfile     BillingProfile?
  scanFees           ScanFee[]
  retentionPayments  RetentionPayment[]

  @@index([email])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ---------------------------------------------------------------------
// DOMAIN — Move Requests (MVP)
// ---------------------------------------------------------------------

enum MoveRequestStatus {
  DRAFT
  PUBLISHED
  AWARDED
  COMPLETED
  CANCELLED
}

enum MoveType {
  HOUSE
  FURNITURE
  BUSINESS
  HEAVY
}

enum CraneRequirement {
  NONE
  SOME
  ALL
}

enum ElevatorSize {
  NONE
  SMALL
  MEDIUM
  LARGE
}

enum TruckAccess {
  EASY
  LIMITED
  NARROW
}

model MoveRequest {
  id     String @id @default(cuid())
  userId String

  // Route (kept for single-stop convenience + summary display).
  // When `multiStop=true` the canonical route lives in MoveRequestStop[].
  fromAddress   String
  fromLat       Float?
  fromLng       Float?
  toAddress     String
  toLat         Float?
  toLng         Float?
  // NOTE: PostGIS columns pickupGeom + dropoffGeom are STORED generated columns
  // managed via prisma/sql/001_postgis_geo.sql. Not visible to Prisma.
  preferredDate DateTime?
  flexDays      Int       @default(0)
  shared        Boolean   @default(false)
  multiStop     Boolean   @default(false)
  type          MoveType  @default(HOUSE)

  // Inventory snapshot (denormalized for MVP)
  itemsJson      Json   @db.JsonB
  itemsCount     Int    @default(0)
  totalVolumeM3  Float  @default(0)
  inventorySource String @default("manual") // "ai" | "manual"

  // Property (defaults; for multi-stop, per-stop values take precedence)
  fromFloor    Int              @default(0)
  toFloor      Int              @default(0)
  fromElevator ElevatorSize     @default(NONE)
  toElevator   ElevatorSize     @default(NONE)
  crane        CraneRequirement @default(NONE)
  packing      Boolean          @default(false)
  truckAccess  TruckAccess      @default(EASY)
  notes        String?          @db.Text

  // Pricing estimate (cents)
  estimatedPriceMinCents Int?
  estimatedPriceMaxCents Int?

  status      MoveRequestStatus @default(PUBLISHED)
  publishedAt DateTime          @default(now())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops   MoveRequestStop[]
  offers  Offer[]
  payment Payment?
  review  Review?
  scanFee ScanFee?

  @@index([userId])
  @@index([status, publishedAt])
}

// ---------------------------------------------------------------------
// SAVED LOCATIONS & INVENTORY
// ---------------------------------------------------------------------

enum LocationType {
  HOME
  OFFICE
  STORAGE
  COUNTRY_HOUSE
  OTHER
}

model SavedLocation {
  id        String       @id @default(cuid())
  userId    String
  name      String
  type      LocationType @default(HOME)
  address   String
  postal    String?
  city      String?
  country   String       @default("GR")
  lat       Float?
  lng       Float?
  floor     Int          @default(0)
  elevator  ElevatorSize @default(NONE)
  notes     String?      @db.Text
  isPrimary Boolean      @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          SavedItem[]
  pickupStops    MoveRequestStop[] @relation("StopFromLocation")
  deliveryStops  MoveRequestStop[] @relation("StopToLocation")

  @@index([userId])
}

enum ItemCondition {
  ASSEMBLED
  MODULAR
  FRAGILE
  EXTRA_CARE
}

model SavedItem {
  id         String  @id @default(cuid())
  userId     String
  locationId String?
  name       String
  category   String?
  length_cm  Float
  width_cm   Float
  height_cm  Float
  volume_m3  Float
  weight_kg  Float?
  quantity   Int     @default(1)
  photoUrl   String? @db.Text
  condition  ItemCondition?
  notes      String? @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  location SavedLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([locationId])
}

// ---------------------------------------------------------------------
// MULTI-STOP MOVES
// ---------------------------------------------------------------------

enum StopType {
  PICKUP
  DELIVERY
}

model MoveRequestStop {
  id            String   @id @default(cuid())
  moveRequestId String
  type          StopType
  sequence      Int      @default(0)
  label         String? // user-given name like "Σπίτι γονιών"

  address String
  postal  String?
  city    String?
  lat     Float?
  lng     Float?

  fromLocationId String?
  toLocationId   String?

  floor       Int              @default(0)
  elevator    ElevatorSize     @default(NONE)
  crane       CraneRequirement @default(NONE)
  truckAccess TruckAccess      @default(EASY)
  notes       String?          @db.Text

  // Items to pick up or drop off at this stop (subset of the request inventory)
  itemsJson Json @db.JsonB

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  moveRequest  MoveRequest    @relation(fields: [moveRequestId], references: [id], onDelete: Cascade)
  fromLocation SavedLocation? @relation("StopFromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocation   SavedLocation? @relation("StopToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)

  @@index([moveRequestId])
}

// ---------------------------------------------------------------------
// OFFERS, PAYMENTS, REVIEWS
// ---------------------------------------------------------------------

enum OfferStatus {
  OPEN
  ACCEPTED
  REJECTED
  EXPIRED
}

model Offer {
  id            String      @id @default(cuid())
  moveRequestId String
  carrierUserId String
  priceCents    Int
  estimatedDays Int?
  notes         String?     @db.Text
  validUntil    DateTime
  status        OfferStatus @default(OPEN)

  // Proposed timeslots for the customer to pick from. Array of
  // { date: "YYYY-MM-DD", period: "MORNING"|"AFTERNOON"|"EVENING" } objects.
  proposedSlotsJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  moveRequest MoveRequest @relation(fields: [moveRequestId], references: [id], onDelete: Cascade)
  carrier     User        @relation("CarrierOffers", fields: [carrierUserId], references: [id], onDelete: Cascade)
  payment     Payment?

  @@index([moveRequestId])
  @@index([carrierUserId])
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

model Payment {
  id            String        @id @default(cuid())
  offerId       String        @unique
  moveRequestId String        @unique
  userId        String
  amountCents   Int
  currency      String        @default("EUR")
  provider      String        @default("viva")
  providerRef   String?
  status        PaymentStatus @default(PENDING)

  authorizedAt DateTime?
  capturedAt   DateTime?
  refundedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offer       Offer       @relation(fields: [offerId], references: [id], onDelete: Cascade)
  moveRequest MoveRequest @relation(fields: [moveRequestId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Review {
  id            String @id @default(cuid())
  moveRequestId String @unique
  authorUserId  String
  carrierUserId String

  rating        Int
  speed         Int?
  care          Int?
  communication Int?
  comment       String? @db.Text

  createdAt DateTime @default(now())

  moveRequest MoveRequest @relation(fields: [moveRequestId], references: [id], onDelete: Cascade)
  author      User        @relation("ReviewAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  carrier     User        @relation("ReviewSubject", fields: [carrierUserId], references: [id], onDelete: Cascade)

  @@index([carrierUserId])
}

// ---------------------------------------------------------------------
// MULTI-TENANT (CARRIER COMPANIES) — admin manages these.
// AADE basic_rec fields map to TRDR (SoftOne) — see lib/aade.ts for the
// canonical mapping (afm→AFM, onomasia→NAME, commer_title→COMMERCIALSTORENAME,
// doy→IRSDATA, postal_*→ADDRESS/ZIP/DISTRICT).
// ---------------------------------------------------------------------

enum TenantStatus {
  ACTIVE
  PAUSED
  SUSPENDED
}

model Tenant {
  id              String   @id @default(cuid())
  vat             String   @unique
  legalName       String
  commercialName  String?
  doyCode         String?
  doyName         String?
  legalStatus     String?
  legalStatusKind String?
  vatSystemFlag   String?
  registeredAt    DateTime?

  address    String?
  addressNo  String?
  postalZip  String?
  postalArea String?
  country    String  @default("GR")

  email   String?
  phone   String?
  website String?

  // HQ coordinates (for service-radius matching). Branches override per-location.
  lat Float?
  lng Float?

  status  TenantStatus @default(ACTIVE)
  logoUrl String?      @db.Text
  notes   String?      @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  branches      Branch[]
  vehicles      Vehicle[]
  subscriptions Subscription[]
  memberships   TenantMembership[]
  itemPrices    CarrierItemPrice[]

  @@index([vat])
  @@index([status])
}

model Branch {
  id             String  @id @default(cuid())
  tenantId       String
  vat            String?
  legalName      String
  commercialName String?
  doyCode        String?
  doyName        String?

  address    String?
  addressNo  String?
  postalZip  String?
  postalArea String?
  country    String  @default("GR")

  email     String?
  phone     String?
  isPrimary Boolean @default(false)

  // Physical Point-Of-Presence (POP) coordinates + service radius in km.
  // The matching engine asks: "which branches are within `serviceRadiusKm`
  // of either pickup or dropoff of the request?" Override per branch so a
  // tenant with branches in Athens + Heraklion can serve both regions.
  lat              Float?
  lng              Float?
  serviceRadiusKm  Int    @default(50)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicles    Vehicle[]
  memberships TenantMembership[]

  @@index([tenantId])
  @@index([vat])
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum VehicleType {
  VAN_SMALL
  VAN_LARGE
  TRUCK_3_5T
  TRUCK_5T
  TRUCK_7_5T
  TRUCK_12T
  TRAILER
  OTHER
}

model Vehicle {
  id          String      @id @default(cuid())
  tenantId    String
  branchId    String?
  plate       String
  brand       String?
  model       String?
  year        Int?
  vehicleType VehicleType @default(VAN_LARGE)
  capacityKg  Float?
  capacityM3  Float?
  fuelType    String?
  color       String?

  // Base / dispatch location. When null, the vehicle's branch location is
  // used. Cost calculations are: base → pickup → dropoff → base × costPerKmCents.
  baseLat        Float?
  baseLng        Float?
  baseAddress    String?
  costPerKmCents Int     @default(0)
  minTripCents   Int     @default(0) // optional minimum charge per trip
  callOutCents   Int     @default(0) // optional fixed dispatch fee

  insuranceExpiresAt DateTime?
  ktoExpiresAt       DateTime?
  registrationDocUrl String?       @db.Text
  photoUrl           String?       @db.Text
  notes              String?       @db.Text
  status             VehicleStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([tenantId, plate])
  @@index([tenantId])
  @@index([branchId])
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

model TenantMembership {
  id       String     @id @default(cuid())
  userId   String
  tenantId String
  branchId String?
  role     TenantRole @default(MEMBER)

  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([branchId])
}

// ---------------------------------------------------------------------
// CUSTOMER BILLING PROFILE — per User. PERSON (receipt) or COMPANY
// (invoice via AADE). Company fields mirror Tenant / SoftOne TRDR.
// ---------------------------------------------------------------------

enum CustomerType {
  PERSON
  COMPANY
}

enum BillingDocumentType {
  RECEIPT
  INVOICE
}

model BillingProfile {
  id     String       @id @default(cuid())
  userId String       @unique
  type   CustomerType @default(PERSON)

  fullName String?
  email    String?
  phone    String?

  // Company-only (populated via AADE lookup)
  vat             String?
  legalName       String?
  commercialName  String?
  doyCode         String?
  doyName         String?
  legalStatus     String?
  legalStatusKind String?
  vatSystemFlag   String?

  // Address (used by both PERSON and COMPANY)
  address    String?
  addressNo  String?
  postalZip  String?
  postalArea String?
  country    String  @default("GR")

  preferredDocument BillingDocumentType @default(RECEIPT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------
// ITEM CATALOG — global standardized list of moving items so every carrier
// quotes against the same SKUs. Customer scans match by key; the catalog
// entry carries names in EL/EN + a default volume estimate.
// ---------------------------------------------------------------------

model ItemCatalog {
  id              String  @id @default(cuid())
  key             String  @unique // stable identifier e.g. "armchair", "wardrobe-2door"
  nameEl          String
  nameEn          String
  category        String? // "furniture", "appliances", "boxes", "other"
  defaultVolumeM3 Float?
  iconKey         String? // optional icon hint
  isActive        Boolean @default(true)
  sortOrder       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prices CarrierItemPrice[]

  @@index([category])
  @@index([isActive, sortOrder])
}

// Per-tenant pricing for catalog items. A row is created lazily when the
// carrier sets a non-zero price; absence = "no preset price" (carrier will
// price the item ad-hoc in each offer).
model CarrierItemPrice {
  id                    String @id @default(cuid())
  tenantId              String
  itemKey               String
  basePriceCents        Int    @default(0)
  craneSurchargeCents   Int    @default(0)
  packingSurchargeCents Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item   ItemCatalog @relation(fields: [itemKey], references: [key], onDelete: Cascade)

  @@unique([tenantId, itemKey])
  @@index([tenantId])
  @@index([itemKey])
}

// ---------------------------------------------------------------------
// TERMS & CONDITIONS — versioned. Only one isActive=true at a time.
// When a new active version is published, all users with a different
// termsAcceptedVersion are forced through /terms/accept on next request.
// ---------------------------------------------------------------------

model TermsVersion {
  id          String   @id @default(cuid())
  version     String   @unique // semver e.g. "1.0.0"
  summary     String?  // 1-2 sentence "what changed"
  bodyEl      String   @db.Text
  bodyEn      String   @db.Text
  isActive    Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

// ---------------------------------------------------------------------
// SYSTEM SETTINGS — singleton row editable by SUPERADMIN.
// All money amounts in EUR cents.
// ---------------------------------------------------------------------

model SystemSettings {
  id String @id @default("default")

  // Data retention
  retentionFreeMonths            Int @default(6)
  retentionExtensionMonthlyCents Int @default(99)
  retentionExtensionYearlyCents  Int @default(990)

  // Gemini AI cap (per user, rolling monthly)
  freeGeminiCallsPerMonth Int @default(5)
  geminiOveragePriceCents Int @default(100)

  // Per move-request fees
  scanFeeCents       Int @default(100)
  manualMoveFeeCents Int @default(0)

  updatedAt   DateTime @updatedAt
  updatedById String?
}

// ---------------------------------------------------------------------
// FEES & RETENTION PAYMENTS
// ---------------------------------------------------------------------

enum ChargeStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  WAIVED
}

model ScanFee {
  id            String  @id @default(cuid())
  userId        String
  moveRequestId String? @unique

  amountCents     Int
  status          ChargeStatus         @default(PENDING)
  documentType    BillingDocumentType?
  paymentProvider String?
  paymentRef      String?
  invoiceMark     String?

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  moveRequest MoveRequest? @relation(fields: [moveRequestId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

model RetentionPayment {
  id     String @id @default(cuid())
  userId String

  amountCents     Int
  monthsAdded     Int
  extendsUntil    DateTime
  status          ChargeStatus         @default(PENDING)
  documentType    BillingDocumentType?
  paymentProvider String?
  paymentRef      String?
  invoiceMark     String?

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ---------------------------------------------------------------------
// SUBSCRIPTIONS — admin defines plans, then assigns to tenants.
// Limits per plan: branches, employees, vehicles, monthly jobs.
// Feature flags: CRM, private scan app, API access, priority support.
// ---------------------------------------------------------------------

model SubscriptionPlan {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text

  maxBranches    Int @default(1)
  maxEmployees   Int @default(5)
  maxVehicles    Int @default(3)
  maxMonthlyJobs Int @default(50)

  crmEnabled         Boolean @default(false)
  privateScanEnabled Boolean @default(false)
  apiAccessEnabled   Boolean @default(false)
  prioritySupport    Boolean @default(false)

  pricePerMonthCents Int  @default(0)
  pricePerYearCents  Int?

  // Commission % SmartMove keeps from each booking executed under this plan
  // (e.g. 5.0 = 5%). Goes alongside / instead of subscription fees.
  commissionPct Float @default(5.0)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  YEARLY
  CUSTOM
}

model Subscription {
  id       String             @id @default(cuid())
  tenantId String
  planId   String
  status   SubscriptionStatus @default(TRIAL)

  maxBranches        Int?
  maxEmployees       Int?
  maxVehicles        Int?
  maxMonthlyJobs     Int?
  crmEnabled         Boolean?
  privateScanEnabled Boolean?
  apiAccessEnabled   Boolean?
  prioritySupport    Boolean?
  commissionPct      Float? // override plan's default %

  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  trialEndsAt DateTime?
  cancelledAt DateTime?

  billingCycle  BillingCycle @default(MONTHLY)
  pricePerCycle Int?
  notes         String?      @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([status])
}
